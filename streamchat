#!/bin/bash
# streamchat — Run Flash-MoE inference with prompt from command line

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "${SCRIPT_DIR}"

HF_CACHE="${HOME}/.cache/huggingface/hub"
MODEL_DIR="${HF_CACHE}/models--mlx-community--Qwen3.5-397B-A17B-4bit/snapshots/39159bd8aa74f5c8446d2b2dc584f62bb51cb0d3"
INFER="./metal_infer/infer"
EXTRACT="./metal_infer/extract_weights.py"
EXPORT_TOK="./metal_infer/export_tokenizer.py"
REPACK="./repack_experts.py"
REPACK_2BIT="./metal_infer/repack_experts_2bit.py"
EXPERT_INDEX="./expert_index.json"
VENV_DIR="./metal_infer/.venv"
VENV_PYTHON="${VENV_DIR}/bin/python3"

PACKED_EXPERTS="${MODEL_DIR}/packed_experts"
EXPERT_SIZE_4BIT_GB=218
EXPERT_SIZE_2BIT_GB=120

MODEL_NAME="Qwen3.5-397B-A17B-4bit"
MODEL_CONTEXT_SIZE=248320

CONFIG_LOCAL="./streamchatrc"
CONFIG_GLOBAL="${HOME}/.streamchatrc"
CONFIG_FILE=""

if [ -f "${CONFIG_LOCAL}" ]; then
    CONFIG_FILE="${CONFIG_LOCAL}"
    source "${CONFIG_FILE}"
elif [ -f "${CONFIG_GLOBAL}" ]; then
    CONFIG_FILE="${CONFIG_GLOBAL}"
    source "${CONFIG_FILE}"
fi

DEFAULT_QUANT="${DEFAULT_QUANT:-4bit}"
DEFAULT_TOKENS="${DEFAULT_TOKENS:-0}"
DEFAULT_TIMING="${DEFAULT_TIMING:-no}"

INFER_ARGS=("$@")

REQUESTED_2BIT=0
for arg in "$@"; do
    if [ "$arg" = "--2bit" ]; then
        REQUESTED_2BIT=1
        break
    fi
done

if [ -n "${DEFAULT_QUANT}" ]; then
    if [ "${DEFAULT_QUANT}" = "2bit" ]; then
        INFER_ARGS+=("--2bit")
    fi
    if [ "${DEFAULT_TIMING}" = "yes" ]; then
        INFER_ARGS+=("--timing")
    fi
fi

if [ -n "${DEFAULT_TOKENS}" ]; then
    INFER_ARGS+=("--tokens" "${DEFAULT_TOKENS}")
fi

SHOW_CONFIG=0
for arg in "$@"; do
    if [ "$arg" = "--config" ]; then
        SHOW_CONFIG=1
        break
    fi
done

if [ "${SHOW_CONFIG}" -eq 1 ]; then
    echo ""
    echo "=== Configuration Settings ==="
    echo ""
    
    if [ -f "${CONFIG_GLOBAL}" ]; then
        echo "Current config file: ${CONFIG_GLOBAL}"
        source "${CONFIG_GLOBAL}"
    elif [ -f "${CONFIG_LOCAL}" ]; then
        echo "Current config file: ${CONFIG_LOCAL}"
        source "${CONFIG_LOCAL}"
    else
        echo "No config file found. Creating new one."
    fi
    
    echo "Current settings:"
    echo "  Quantization: ${DEFAULT_QUANT:-4bit}"
    echo "  Context window: ${DEFAULT_TOKENS:-0}"
    echo "  Timing: ${DEFAULT_TIMING:-no}"
    echo ""
    
    echo "Model: ${MODEL_NAME}"
    echo "Max context window: ${MODEL_CONTEXT_SIZE} tokens"
    echo ""
    read -p "Set context window (default: ${DEFAULT_TOKENS:-0}): " -n 10 -r
    echo ""
    
    NEW_TOKENS="${REPLY:-${DEFAULT_TOKENS:-0}}"
    
    if [ "${NEW_TOKENS}" = "${DEFAULT_TOKENS:-0}" ]; then
        echo ""
        echo "No changes to ${CONFIG_GLOBAL}"
        echo "  Quantization: ${DEFAULT_QUANT:-4bit}"
        echo "  Context window: ${DEFAULT_TOKENS:-0}"
        echo ""
        exit 0
    fi
    
    cat > "${CONFIG_GLOBAL}" << EOF
# streamchat configuration
# Generated on $(date)

DEFAULT_QUANT="${DEFAULT_QUANT:-4bit}"
DEFAULT_TOKENS="${NEW_TOKENS}"
DEFAULT_TIMING="${DEFAULT_TIMING:-no}"
EOF
    echo ""
    echo "Config saved to ${CONFIG_GLOBAL}"
    echo "  Quantization: ${DEFAULT_QUANT:-4bit}"
    echo "  Context window: ${NEW_TOKENS}"
    echo ""
    exit 0
fi

# Auto-enable venv if not already active
if [ -z "${VENV_ACTIVE}" ] && [ -f "${VENV_PYTHON}" ]; then
    CURRENT_PYTHON=$(command -v python3 2>/dev/null || echo "")
    if [ "${CURRENT_PYTHON}" != "${VENV_PYTHON}" ]; then
        export VENV_ACTIVE=1
        exec bash "$0" "$@"
    fi
fi

if [ ! -f "${VENV_PYTHON}" ]; then
    echo "Error: Virtual environment not found at ${VENV_DIR}" >&2
    echo "Create it with: python3 -m venv ${VENV_DIR} && ${VENV_DIR}/bin/pip install numpy" >&2
    exit 1
fi

if [ ! -f "${INFER}" ]; then
    INFER="./infer"
fi

if [ ! -f "${INFER}" ]; then
    echo "Error: infer binary not found. Run 'make' in metal_infer/ first." >&2
    exit 1
fi

if [ ! -d "${MODEL_DIR}" ]; then
    echo "Error: Model not found at ${MODEL_DIR}" >&2
    echo "Download with: huggingface-cli download mlx-community/Qwen3.5-397B-A17B-4bit" >&2
    exit 1
fi

# Check for model_weights.bin (non-expert weights)
WEIGHTS_DIR="./metal_infer"
WEIGHTS_BIN="${WEIGHTS_DIR}/model_weights.bin"
WEIGHTS_JSON="${WEIGHTS_DIR}/model_weights.json"

if [ ! -f "${WEIGHTS_BIN}" ] || [ ! -f "${WEIGHTS_JSON}" ]; then
    echo ""
    echo "First-time setup: extracting model weights (~5.5GB) from safetensors..."
    echo "This is a ONE-TIME operation and may take several minutes."
    echo ""
    echo "Extracting to metal_infer/model_weights.bin..."
    echo ""

    python3 "${EXTRACT}" --model "${MODEL_DIR}" --output "${WEIGHTS_DIR}"

    echo ""
    echo "Weights extracted successfully."
    echo ""
fi

# Check for vocab.bin (tokenizer)
VOCAB_BIN="${WEIGHTS_DIR}/vocab.bin"
if [ ! -f "${VOCAB_BIN}" ]; then
    echo ""
    echo "First-time setup: creating vocabulary binary from tokenizer.json..."
    echo ""

    python3 "${EXPORT_TOK}" "${MODEL_DIR}/tokenizer.json" "${VOCAB_BIN}"

    echo ""
    echo "Vocabulary created successfully."
    echo ""
fi

# Check for packed_experts (4-bit high resolution inference)
PACKED_LAYER="${PACKED_EXPERTS}/layer_00.bin"
PACKED_2BIT="${MODEL_DIR}/packed_experts_2bit/layer_00.bin"

if [ ! -f "${EXPERT_INDEX}" ]; then
    echo "Error: expert_index.json not found at ${EXPERT_INDEX}" >&2
    echo "This file is required to extract expert weights." >&2
    exit 1
fi

EXTRACTION_MODE=""

NEED_EXTRACTION=0
if [ ! -f "${PACKED_LAYER}" ]; then
    NEED_EXTRACTION=1
elif [ "${REQUESTED_2BIT}" -eq 1 ] && [ ! -f "${PACKED_2BIT}" ]; then
    NEED_EXTRACTION=1
fi

if [ "${NEED_EXTRACTION}" -eq 1 ]; then
    echo ""
    echo "=== Expert Weight Extraction ==="
    echo ""

    DISK_INFO=$(df -h "${MODEL_DIR}" 2>/dev/null | tail -1)
    if [ -n "${DISK_INFO}" ]; then
        FREE_SPACE=$(echo "${DISK_INFO}" | awk '{print $4}')
        echo "Available disk space: ${FREE_SPACE}"
    fi
    echo ""

    echo "Expert weights are required for inference. Choose extraction mode:"
    echo ""
    echo "  [4] 4-bit mode (~${EXPERT_SIZE_4BIT_GB}GB)  - Full quality, tool calling supported"
    echo "  [2] 2-bit mode (+~${EXPERT_SIZE_2BIT_GB}GB, requires 4-bit first) - Faster but breaks tool calling"
    echo "  [Q] Quit"
    echo ""
    echo "This is a ONE-TIME setup that takes significant time."
    echo ""

    read -p "Select option [4/2/Q]: " -n 1 -r
    echo ""
    echo ""

    if [[ $REPLY =~ ^[4]$ ]]; then
        EXTRACTION_MODE="4bit"
    elif [[ $REPLY =~ ^[2]$ ]]; then
        EXTRACTION_MODE="2bit"
    elif [[ $REPLY =~ ^[Qq]$ ]]; then
        echo "Run './streamchat' again when ready to extract expert weights."
        echo ""
        exit 0
    else
        echo "Invalid option. Please select 4, 2, or Q."
        echo ""
        exit 1
    fi

    echo ""
    echo "=== Model Information ==="
    echo ""
    echo "Model: ${MODEL_NAME}"
    echo "Max context window: ${MODEL_CONTEXT_SIZE} tokens"
    echo ""
    read -p "Set context window (default: 0 = max supported): " -n 10 -r
    echo ""
    echo ""

    CONFIG_TOKENS="${REPLY:-0}"
fi

if [ -z "${CONFIG_FILE}" ] && [ -t 0 ] && [ -n "${EXTRACTION_MODE}" ]; then
    echo ""
    echo "=== Save Settings? ==="
    echo ""
    echo "Would you like to save these settings to a config file?"
    echo "Config file location: ${CONFIG_GLOBAL}"
    echo ""
    echo "Current settings:"
    echo "  Quantization: ${EXTRACTION_MODE}"
    echo "  Context window: ${CONFIG_TOKENS:-0}"
    echo ""
    read -p "Save to config file? (y/N): " -n 1 -r
    echo ""

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        cat > "${CONFIG_GLOBAL}" << EOF
# streamchat configuration
# Generated on $(date)

DEFAULT_QUANT="${EXTRACTION_MODE}"
DEFAULT_TOKENS="${CONFIG_TOKENS:-0}"
DEFAULT_TIMING="${DEFAULT_TIMING:-no}"
EOF
        echo "Config saved to ${CONFIG_GLOBAL}"
        CONFIG_FILE="${CONFIG_GLOBAL}"
    fi
    echo ""
fi

if [ -n "${EXTRACTION_MODE}" ]; then
    if [[ $EXTRACTION_MODE == "4bit" ]]; then
        if [ ! -f "${PACKED_LAYER}" ]; then
            echo "Extracting 4-bit experts to ${PACKED_EXPERTS}..."
            echo "Estimated time: 30-60 minutes."
            echo ""

            python3 "${REPACK}" --index "${EXPERT_INDEX}"

            echo ""
            echo "4-bit experts extracted successfully."
            echo ""
        else
            echo "4-bit experts already exist, skipping extraction."
            echo ""
        fi
    elif [[ $EXTRACTION_MODE == "2bit" ]]; then
        if [ ! -f "${PACKED_LAYER}" ]; then
            echo "4-bit experts not found. Extracting 4-bit first..."
            echo ""

            python3 "${REPACK}" --index "${EXPERT_INDEX}"

            echo ""
            echo "4-bit experts extracted."
            echo ""
        fi

        if [ ! -f "${PACKED_2BIT}" ]; then
            echo "Requantizing to 2-bit format..."
            echo "Estimated time: 15-30 minutes."
            echo ""

            python3 "${REPACK_2BIT}"

            echo ""
            echo "2-bit experts created successfully."
            echo ""
        else
            echo "2-bit experts already exist, skipping."
            echo ""
        fi
    fi
fi

if [ -z "${INFER_ARGS[*]}" ]; then
    echo "Usage: ./streamchat <prompt> [options]" >&2
    echo "" >&2
    if [ -n "${CONFIG_FILE}" ]; then
        echo "Defaults (from ${CONFIG_FILE}):" >&2
        echo "  Quantization: ${DEFAULT_QUANT}" >&2
        echo "  Tokens: ${DEFAULT_TOKENS}" >&2
        echo "  Timing: ${DEFAULT_TIMING}" >&2
        echo "" >&2
    fi
    echo "Options:" >&2
    echo "  --2bit               Use 2-bit quantized experts (faster, breaks tool calling)" >&2
    echo "  --tokens N           Number of tokens to generate (default: 20)" >&2
    echo "  --timing             Show per-layer timing breakdown" >&2
    echo "  --config             Configure default settings (context window, etc.)" >&2
    echo "" >&2
    echo "Config:" >&2
    echo "  ~/.streamchatrc or ./streamchatrc for default settings" >&2
    echo "" >&2
    echo "Examples:" >&2
    echo "  ./streamchat Explain quantum computing in one sentence" >&2
    echo "  ./streamchat --2bit Explain quantum computing" >&2
    echo "  ./streamchat --tokens 50 Hello world" >&2
    exit 1
fi

if [ -n "${CONFIG_FILE}" ]; then
    echo ""
    echo "Using config: ${CONFIG_FILE}"
    echo "  Quantization: ${DEFAULT_QUANT}"
    echo "  Context window: ${DEFAULT_TOKENS:-max}"
    echo "  Timing (benchmarking): ${DEFAULT_TIMING}"
    echo ""
    echo "Press Ctrl+C to cancel..."
    sleep 1
fi

PROMPT_TEXT=""
INFER_OPTS=()
NEXT_IS_TOKENS=0

if [ -n "${DEFAULT_QUANT}" ]; then
    if [ "${DEFAULT_QUANT}" = "2bit" ]; then
        INFER_OPTS+=("--2bit")
    fi
    if [ "${DEFAULT_TIMING}" = "yes" ]; then
        INFER_OPTS+=("--timing")
    fi
fi

if [ -n "${DEFAULT_TOKENS}" ]; then
    INFER_OPTS+=("--tokens" "${DEFAULT_TOKENS}")
fi

for arg in "$@"; do
    if [ "${NEXT_IS_TOKENS}" = "1" ]; then
        INFER_OPTS+=("--tokens" "$arg")
        NEXT_IS_TOKENS=0
    elif [ "$arg" = "--tokens" ]; then
        NEXT_IS_TOKENS=1
    elif [ "$arg" = "--2bit" ] || [ "$arg" = "--timing" ]; then
        INFER_OPTS+=("$arg")
    else
        PROMPT_TEXT="${PROMPT_TEXT}${PROMPT_TEXT:+ }${arg}"
    fi
done

exec "${INFER}" --model "${MODEL_DIR}" "${INFER_OPTS[@]}" --prompt "${PROMPT_TEXT}"
